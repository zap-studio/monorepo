{
  "name": "@zap-studio/fetch",
  "version": "0.4.7",
  "private": false,
  "description": "A type-safe fetch wrapper for HTTP requests with runtime schema validation.",
  "keywords": [
    "api",
    "arktype",
    "error handling",
    "fetch",
    "http",
    "request",
    "response",
    "runtime validation",
    "schema",
    "standard schema",
    "type-safe",
    "typescript",
    "valibot",
    "validation",
    "zod"
  ],
  "homepage": "https://www.zapstudio.dev/packages/fetch",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zap-studio/monorepo.git",
    "directory": "packages/fetch"
  },
  "bin": {
    "intent": "./bin/intent.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "skills",
    "bin",
    "!skills/_artifacts"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./constants": "./dist/constants.mjs",
    "./errors": "./dist/errors.mjs",
    "./types": "./dist/types.mjs",
    "./utils": "./dist/utils.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "typecheck": "tsc --noEmit",
    "test": "vp test run",
    "test:watch": "vp test watch"
  },
  "dependencies": {
    "@zap-studio/validation": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@zap-studio/typescript-config": "workspace:*",
    "arktype": "catalog:",
    "typescript": "catalog:",
    "valibot": "catalog:",
    "vite-plus": "catalog:",
    "zod": "catalog:"
  }
}
