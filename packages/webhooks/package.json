{
  "name": "@zap-studio/webhooks",
  "version": "0.1.1",
  "type": "module",
  "license": "MIT",
  "private": false,
  "homepage": "https://www.zapstudio.dev/packages/webhooks",
  "repository": {
    "type": "git",
    "url": "https://github.com/zap-studio/monorepo.git",
    "directory": "packages/webhooks"
  },
  "description": "A lightweight, type-safe webhook router with Standard Schema validation, signature verification, and lifecycle hooks.",
  "keywords": [
    "webhooks",
    "webhook router",
    "type-safe",
    "typescript",
    "validation",
    "schema",
    "standard schema",
    "zod",
    "valibot",
    "arktype",
    "signature verification",
    "lifecycle hooks",
    "payload validation"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@standard-schema/spec": "catalog:base",
    "@zap-studio/validation": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "@vitest/coverage-v8": "catalog:testing",
    "@zap-studio/tsdown-config": "workspace:*",
    "@zap-studio/typescript-config": "workspace:*",
    "@zap-studio/vitest-config": "workspace:*",
    "tsdown": "catalog:base",
    "typescript": "catalog:base",
    "vitest": "catalog:testing",
    "zod": "catalog:base"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./adapters/base": "./dist/adapters/base.mjs",
    "./types": "./dist/types/index.mjs",
    "./utils": "./dist/utils/index.mjs",
    "./verify": "./dist/verify.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts"
}
