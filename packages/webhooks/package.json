{
  "name": "@zap-studio/webhooks",
  "version": "0.2.0",
  "private": false,
  "description": "A lightweight, type-safe webhook router with Standard Schema validation, signature verification, and lifecycle hooks.",
  "keywords": [
    "arktype",
    "lifecycle hooks",
    "payload validation",
    "schema",
    "signature verification",
    "standard schema",
    "type-safe",
    "typescript",
    "valibot",
    "validation",
    "webhook router",
    "webhooks",
    "zod"
  ],
  "homepage": "https://www.zapstudio.dev/packages/webhooks",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zap-studio/monorepo.git",
    "directory": "packages/webhooks"
  },
  "bin": {
    "intent": "./bin/intent.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "skills",
    "bin",
    "!skills/_artifacts"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./adapters/base": "./dist/adapters/base.mjs",
    "./errors": "./dist/errors.mjs",
    "./types": "./dist/types/index.mjs",
    "./utils": "./dist/utils/index.mjs",
    "./verify": "./dist/verify.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "publish:check": "publint --strict --pack pnpm && attw --profile esm-only --pack .",
    "test": "vp test run",
    "test:watch": "vp test watch"
  },
  "dependencies": {
    "@zap-studio/validation": "workspace:*"
  },
  "devDependencies": {
    "@zap-studio/typescript": "workspace:*",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "zod": "catalog:"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
